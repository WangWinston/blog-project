# Environment Variables for Blog System
# Copy this file to .env and modify values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root123
MYSQL_PASSWORD=blog123

# JWT Configuration (change this in production!)
JWT_SECRET=blog-prod-secret-key-must-be-at-least-256-bits-long-for-hs256

# GitHub OAuth (configure these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://your-domain/api/auth/github/callback