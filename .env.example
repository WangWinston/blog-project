# 环境变量配置
# 复制此文件为 .env 并修改配置

# ===== MySQL 配置 =====
MYSQL_ROOT_PASSWORD=root123
MYSQL_PASSWORD=blog123

# ===== Redis 配置 =====
REDIS_PASSWORD=

# ===== JWT 配置 =====
# 密钥至少256位，生产环境请修改
JWT_SECRET=blog-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=7200000

# ===== GitHub OAuth (可选) =====
# 不使用 GitHub 登录可留空
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://your-domain/api/auth/github/callback